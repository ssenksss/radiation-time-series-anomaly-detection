```gitignore
# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

venv/
.venv/
env/
backend/venv/
backend/.venv/

*.log


# =========================
# Environment variables
# =========================
.env
.env.local
.env.*.local
backend/.env
frontend/.env
frontend/.env.local

# Keep examples
!.env.example


# =========================
# Node / Vue
# =========================
node_modules/
frontend/node_modules/

dist/
dist-ssr/
frontend/dist/

*.local


# =========================
# Database / local storage
# =========================
*.db
*.sqlite
*.sqlite3

postgres-data/
pgdata/
database/data/


# =========================
# Uploaded files / generated data
# =========================
uploads/
backend/uploads/

# Keep mock dataset if it is part of the project,
# but do not commit real uploaded datasets by accident.
ml/datasets/real_*.csv
ml/datasets/uploaded_*.csv


# =========================
# ML generated outputs
# =========================
ml/outputs/*
!ml/outputs/.gitkeep


# =========================
# System files
# =========================
.DS_Store
__MACOSX__


# =========================
# IDE / editors
# =========================
.idea/
.vscode/
*.iml
```
